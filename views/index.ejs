<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Labs | Web Security Home Labs</title>
    <style>
        /* Base Dark Theme */
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background-color: #0a0a0a; 
            color: #e0e0e0; 
            margin: 0; 
            display: flex; 
            min-height: 100vh;
        }

        /* --- SIDEBAR TOPIC NAVIGATION --- */
        .sidebar {
            width: 320px;
            background-color: #111;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            transition: all 0.3s ease;
        }

        .sidebar-header {
            padding: 20px;
            display: flex;
            justify-content: flex-end; /* Aligns the X to the right since we removed the back link */
            align-items: center;
            border-bottom: 1px solid #222;
        }

        .close-btn {
            color: #888;
            font-size: 1.5em;
            cursor: pointer;
            transition: color 0.2s;
            line-height: 1;
        }

        .close-btn:hover { color: #ff4d4d; }

        .topic-list {
            list-style: none;
            padding: 0;
            margin: 10px 0;
        }

        .topic-list li a {
            display: block;
            padding: 12px 20px;
            color: #ccc;
            text-decoration: none;
            font-size: 0.95em;
            transition: all 0.2s;
            border-left: 3px solid transparent; 
        }

        .topic-list li a:hover {
            background-color: #1a1a1a;
            color: #fff;
        }

        .topic-list li.active a {
            background-color: rgba(124, 77, 255, 0.1); 
            border-left-color: #ff4d4d; 
            color: #fff;
            font-weight: 600;
        }

        /* --- MAIN LAYOUT --- */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        /* Top Navigation Bar */
        .navbar {
            background-color: #141414;
            border-bottom: 2px solid #7c4dff; 
            padding: 15px 40px;
            display: flex;
            align-items: center;
            gap: 15px; /* Spaces the hamburger menu and the brand */
            position: sticky;
            top: 0;
            z-index: 1000;
        }
/* Add these inside your <style> tags */
        .lab-meta { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            margin-bottom: 12px; 
        }
        
        .lab-status { 
            padding: 3px 8px; 
            border-radius: 4px; 
            font-size: 0.8em; 
            font-weight: bold; 
        }
        
        /* Solved: Bright Purple */
        .status-solved { 
            background-color: #7c4dff; 
            color: #fff; 
            box-shadow: 0 0 8px rgba(124, 77, 255, 0.4);
        }
        
        /* Unsolved: Blends into the background */
        .status-unsolved { 
            background-color: #141414; /* Matches the main container background */
            color: #444; /* Dark grey text so it's barely visible */
            border: 1px solid #222; 
        }
        .menu-toggle {
            color: #888;
            font-size: 1.5em;
            cursor: pointer;
            display: none; /* Hidden by default while sidebar is open */
            transition: color 0.2s;
        }

        .menu-toggle:hover {
            color: #b388ff;
        }

        .nav-brand {
            color: #e0e0e0;
            font-size: 1.4em;
            font-weight: bold;
            text-decoration: none;
            letter-spacing: 1px;
        }

        .nav-brand span { color: #ff4d4d; }

        /* Main Content Container */
        .container { 
            max-width: 1000px; 
            margin: 40px auto; 
            width: 90%;
            background: #141414; 
            padding: 30px; 
            border-radius: 8px; 
            border: 1px solid #333;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5); 
        }

        h1 { color: #b388ff; border-bottom: 2px solid #333; padding-bottom: 10px; margin-top: 0; }
        
        .dashboard-header {
            display: flex; justify-content: space-between; background: #1a1a1a;
            padding: 15px; border-radius: 6px; border-left: 4px solid #ff4d4d; 
            margin-bottom: 20px; font-size: 0.9em;
        }

        .category { margin-top: 40px; }
        .category h2 { color: #f5f5f5; font-size: 1.5em; border-left: 3px solid #b388ff; padding-left: 10px; }
        .coming-soon { color: #ff4d4d; font-family: monospace; background: #1a1a1a; padding: 15px; border-radius: 5px; border: 1px dashed #555; }
        .lab-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 15px; }
        .lab-card { border: 1px solid #333; border-radius: 6px; padding: 20px; background: #1a1a1a; transition: all 0.2s ease-in-out; display: flex; flex-direction: column; }
        .lab-card:hover { border-color: #b388ff; box-shadow: 0 0 10px rgba(179, 136, 255, 0.2); transform: translateY(-2px); }
        .lab-difficulty { display: inline-block; background: rgba(255, 77, 77, 0.1); color: #ff4d4d; border: 1px solid #ff4d4d; padding: 3px 8px; border-radius: 4px; font-size: 0.8em; font-weight: bold; margin-bottom: 12px; align-self: flex-start; }
        .lab-title { font-size: 1.2em; font-weight: bold; margin: 0 0 10px 0; color: #fff; }
        .lab-desc { font-size: 0.9em; color: #aaa; margin-bottom: 20px; line-height: 1.5; flex-grow: 1; }
        .btn { display: inline-block; background: #7c4dff; color: white; text-decoration: none; padding: 8px 15px; border-radius: 4px; font-size: 0.9em; font-weight: bold; text-align: center; transition: background 0.2s; }
        .btn:hover { background: #ff4d4d; }
    </style>
</head>
<body>

<aside class="sidebar" id="topicSidebar">
    <div class="sidebar-header">
        <span class="close-btn" id="closeSidebarBtn" title="Close menu">&times;</span>
    </div>
    <ul class="topic-list">
        <li><a href="#">SQL injection</a></li>
        <li><a href="#">Cross-site scripting</a></li>
        <li><a href="#">Cross-site request forgery (CSRF)</a></li>
        <li><a href="#">Clickjacking</a></li>
        <li><a href="#">DOM-based vulnerabilities</a></li>
        <li><a href="#">Cross-origin resource sharing (CORS)</a></li>
        <li><a href="#">XML external entity (XXE) injection</a></li>
        <li class="active"><a href="#ssrf">Server-side request forgery (SSRF)</a></li>
        <li><a href="#">HTTP request smuggling</a></li>
        <li><a href="#">OS command injection</a></li>
        <li><a href="#">Server-side template injection</a></li>
        <li><a href="#">Path traversal</a></li>
        <li><a href="#">Access control vulnerabilities</a></li>
        <li><a href="#">Authentication</a></li>
        <li><a href="#">WebSockets</a></li>
        <li><a href="#">Web cache poisoning</a></li>
        <li><a href="#">Insecure deserialization</a></li>
        <li><a href="#">Information disclosure</a></li>
        <li><a href="#">Business logic vulnerabilities</a></li>
        <li><a href="#">HTTP Host header attacks</a></li>
        <li><a href="#">OAuth authentication</a></li>
        <li><a href="#">File upload vulnerabilities</a></li>
    </ul>
</aside>

<div class="main-wrapper">
    <nav class="navbar">
        <span class="menu-toggle" id="openSidebarBtn" title="Open menu">&#9776;</span>
        <a href="/" class="nav-brand">Home <span>Labs</span></a>
    </nav>

    <div class="container">
        <h1>All Web Security Labs</h1>

        <% categories.forEach(function(category) { %>
            <div class="category" id="<%= category.id %>">
                <h2><%= category.title %></h2>

                <% if (category.labs.length > 0) { %>
                    <div class="lab-grid">
                        <% category.labs.forEach(function(lab) { %>
                            <div class="lab-card">
                                <div class="lab-meta">
                                    <span class="lab-difficulty"><%= lab.difficulty %></span>
                                    
                                    <% if (lab.is_solved) { %>
                                        <span class="lab-status status-solved">&#10003; Solved</span>
                                    <% } else { %>
                                        <span class="lab-status status-unsolved">Unsolved</span>
                                    <% } %>
                                </div>
                                
                                <h3 class="lab-title"><%= lab.title %></h3>
                                <p class="lab-desc"><%= lab.description.substring(0, 100) %>...</p>
                                <a href="/<%= category.id %>/<%= lab.id %>" class="btn">View Details</a>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="coming-soon">
                        [!] Labs for this category are currently under construction. &lt;coming soon&gt;
                    </div>
                <% } %>
            </div>
        <% }); %>

    </div>
</div>

<script>
    const sidebar = document.getElementById('topicSidebar');
    const closeBtn = document.getElementById('closeSidebarBtn');
    const openBtn = document.getElementById('openSidebarBtn');

    // Hide sidebar and show hamburger menu
    closeBtn.addEventListener('click', () => {
        sidebar.style.display = 'none';
        openBtn.style.display = 'block';
    });

    // Show sidebar and hide hamburger menu
    openBtn.addEventListener('click', () => {
        sidebar.style.display = 'flex';
        openBtn.style.display = 'none';
    });
</script>

</body>
</html>